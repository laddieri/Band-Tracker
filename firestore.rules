rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────
    // Membership is claims-first with a doc fallback. When the token carries
    // orgId/role custom claims (mirrored from /members/{uid} by the
    // syncMemberClaims Cloud Function — see functions/), they are trusted and
    // no read happens. Tokens without claims (function not yet deployed, or a
    // token minted before the member doc existed) fall back to get()-ing
    // /members/{uid}, which costs one extra read per request — the pre-claims
    // behavior. Claims are authoritative when present: a mismatched member doc
    // cannot widen access.
    //
    // Tradeoff to know about: claims live in the ID token, so removing a
    // member leaves their existing token valid for up to ~1 hour (the function
    // revokes refresh tokens on member delete, which blocks minting new ones).
    // The doc-fallback model revoked instantly. See docs/MULTI_TENANCY_RUNBOOK.md.

    function isSignedIn() {
      return request.auth != null;
    }

    function isAnonymous() {
      return request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    // Key-existence check with `in`: reading a MISSING token key errors in
    // rules (it does not yield null), and an error inside a condition denies —
    // which would lock out every claims-less (fallback) user.
    function hasClaims() {
      return 'orgId' in request.auth.token;
    }

    function memberPath() {
      return /databases/$(database)/documents/members/$(request.auth.uid);
    }

    function isMember() {
      return isSignedIn() && exists(memberPath());
    }

    function member() {
      return get(memberPath()).data;
    }

    // True if the caller is a member of the given org (any role).
    function belongsTo(orgId) {
      return isSignedIn() && (
        hasClaims()
          ? request.auth.token.orgId == orgId
          : (isMember() && member().orgId == orgId)
      );
    }

    // True if the caller is a director of the given org.
    function isDirectorOf(orgId) {
      return isSignedIn() && (
        hasClaims()
          ? (request.auth.token.orgId == orgId && request.auth.token.role == 'director')
          : (isMember() && member().orgId == orgId && member().role == 'director')
      );
    }

    // The caller's own student number (null for directors / no membership).
    function myStudentNumber() {
      return hasClaims()
        ? (('studentNumber' in request.auth.token) ? request.auth.token.studentNumber : null)
        : member().studentNumber;
    }

    // ── Per-org data (subcollections) ─────────────────────────────────────────
    // Writes: directors of the org only. Reads are scoped per collection:
    // students only ever see their own records plus the director-published
    // settings/public snapshot — never the raw roster, other students' marks,
    // song results, or director-only settings. See "Student data visibility"
    // in docs/DATA_MODEL.md.

    match /orgs/{orgId} {

      // Org metadata. Director-only read: this doc carries the co-director
      // invite code, which must never be visible to students (a student who
      // read it could join their own org as a director). During the controlled
      // rollout, creating a band requires a valid access code (a doc in
      // /accessCodes managed by the operator). No client deletes.
      allow read:   if isDirectorOf(orgId);
      allow create: if isSignedIn() && !isAnonymous()
                    && request.resource.data.createdBy == request.auth.uid
                    && exists(/databases/$(database)/documents/accessCodes/$(request.resource.data.accessCode));
      allow update: if isDirectorOf(orgId);
      allow delete: if false;

      function canRead()  { return belongsTo(orgId); }
      function canWrite() { return isDirectorOf(orgId); }

      // settings/public is the student-safe doc that director clients publish
      // (branding, feature flags, derived stats with pseudonyms). Everything
      // else under settings — notably 'presets', which holds the pseudonym
      // salt, score weights and drill data — is director-only.
      match /settings/{doc} {
        allow read:  if canWrite() || (doc == 'public' && canRead());
        allow write: if canWrite();
      }

      // A student may read only their own roster doc (doc id == their number).
      match /students/{doc} {
        allow read:  if canWrite() || (canRead() && myStudentNumber() == doc);
        allow write: if canWrite();
      }

      // Rehearsal metadata (dates/labels) is schedule info — safe for members.
      match /rehearsals/{doc} {
        allow read:  if canRead();
        allow write: if canWrite();
      }

      // A student may read only their own entries. Student clients must query
      // with where('studentNumber', '==', <own number>) so the rule can be
      // proven for the whole query.
      match /entries/{doc} {
        allow read:  if canWrite() || (canRead() && resource.data.studentNumber == myStudentNumber());
        allow write: if canWrite();
      }

      // Song docs embed every student's pass/fail status and fail notes, so
      // they are director-only. Students get the song catalog + aggregate
      // progress from settings/public, and their own results from the
      // songStatuses mirror on their own student doc.
      match /songs/{doc} {
        allow read:  if canWrite();
        allow write: if canWrite();
      }

      // Drill library (Pyware field charts). Director-only — students never see
      // drill data. The heavy position payload lives in a /data subcollection
      // so listing the library stays cheap.
      match /drills/{drillId} {
        allow read:  if canWrite();
        allow write: if canWrite();

        match /data/{doc} {
          allow read:  if canWrite();
          allow write: if canWrite();
        }
      }
    }

    // ── Membership ────────────────────────────────────────────────────────────
    // A user may read their own membership; directors may read (and remove)
    // members of their own org for the Directors management UI. Creating a
    // membership is how a user joins an org; the rules ensure you can only join
    // an org you are entitled to.

    match /members/{uid} {
      allow read: if isSignedIn() && (
        request.auth.uid == uid
        || isDirectorOf(resource.data.orgId)
      );

      // Director join: allowed if you either created the org (create-a-band) or
      // hold a valid invite code that maps to it (co-director invite).
      function directorJoin() {
        let m = request.resource.data;
        return !isAnonymous()
          && m.role == 'director'
          && (
            (exists(/databases/$(database)/documents/orgs/$(m.orgId))
              && get(/databases/$(database)/documents/orgs/$(m.orgId)).data.createdBy == request.auth.uid)
            ||
            (m.inviteCode is string
              && exists(/databases/$(database)/documents/inviteCodes/$(m.inviteCode))
              && get(/databases/$(database)/documents/inviteCodes/$(m.inviteCode)).data.orgId == m.orgId)
          );
      }

      // Student self-join: only with a valid student code, and only to claim the
      // exact student number that code maps to. Without the studentNumber check a
      // holder of ANY valid code in the org could bind their uid to someone
      // else's number and read that student's data (students talk to Firestore
      // directly, so this rule — not the UI — is the boundary).
      //
      // The synthetic student email proves possession of the PIN (Firebase
      // verified it at sign-in) and must match the code being claimed. Student
      // codes are NOT secret — the PIN is — so there is deliberately no
      // anonymous path here: an anonymous caller holding a code has proven
      // nothing. (A legacy anonymous escape hatch was removed; students from
      // that era simply re-enter their code and set a PIN.)
      function studentJoin() {
        let m    = request.resource.data;
        let code = /databases/$(database)/documents/studentCodes/$(m.joinCode);
        return m.role == 'student'
          && !isAnonymous()
          && exists(code)
          && get(code).data.orgId == m.orgId
          && get(code).data.studentNumber == m.studentNumber
          && request.auth.token.email == m.joinCode.lower() + '@students.bandtracker.app';
      }

      allow create: if isSignedIn() && request.auth.uid == uid
                    && (directorJoin() || studentJoin());
      allow update: if false;

      // A director may remove a member of their own org, but never the org's
      // creator — so a band always keeps at least one director.
      allow delete: if isDirectorOf(resource.data.orgId)
                    && get(/databases/$(database)/documents/orgs/$(resource.data.orgId)).data.createdBy != uid;
    }

    // ── Student code lookup ───────────────────────────────────────────────────
    // Readable by any signed-in user so an anonymous student can resolve their
    // org before a membership exists. Contains no sensitive data (org id + a
    // student number). Only directors of the owning org may manage codes.

    match /studentCodes/{code} {
      // Fetchable by a known code WITHOUT being signed in — a student must look
      // up / validate their code before they have any account (the synthetic
      // email + PIN login has no anonymous bootstrap session). Still NOT
      // listable, so the collection can't be enumerated, and it exposes nothing
      // sensitive (just an org id + a student number) and is not brute-forceable
      // by id in practice (32^8 space).
      allow get:    if true;
      allow list:   if false;
      allow create: if isDirectorOf(request.resource.data.orgId);
      allow update: if (isDirectorOf(resource.data.orgId) && isDirectorOf(request.resource.data.orgId))
                    || studentMarksClaimed();
      allow delete: if isDirectorOf(resource.data.orgId);

      // The matching student (authenticated with the synthetic email for THIS
      // code) may flip claimed=true on their own code, without touching the org
      // or number it maps to. Lets the sign-in wizard route returning students
      // straight to the PIN screen vs first-timers to the set-PIN screen.
      function studentMarksClaimed() {
        return request.auth != null
          && request.auth.token.email == code.lower() + '@students.bandtracker.app'
          && request.resource.data.orgId == resource.data.orgId
          && request.resource.data.studentNumber == resource.data.studentNumber
          && request.resource.data.claimed == true;
      }
    }

    // ── Co-director invite codes ──────────────────────────────────────────────
    // Readable by any signed-in user so a joining director can resolve the org
    // before a membership exists. Exposes only an org id. Managed by the org's
    // directors.

    match /inviteCodes/{code} {
      // Fetchable by a known code (a joining co-director resolves the org before
      // membership) but NOT listable — enumerating these would let anyone harvest
      // a valid invite code and join an org as a director.
      allow get:    if isSignedIn();
      allow list:   if false;
      allow create: if isDirectorOf(request.resource.data.orgId);
      allow update: if isDirectorOf(resource.data.orgId)
                    && isDirectorOf(request.resource.data.orgId);
      allow delete: if isDirectorOf(resource.data.orgId);
    }

    // ── Access codes (controlled rollout gate) ────────────────────────────────
    // Gates creating a brand-new band. The org-create rule above checks that
    // /accessCodes/{code} exists. These docs are never read or written by
    // clients — rule get()/exists() can read them regardless, so they stay
    // secret. Manage them in the Firebase Console (add/remove to open or close
    // signups). Remove this collection's use from the org-create rule when you
    // want fully open self-serve signup.
    match /accessCodes/{code} {
      allow read, write: if false;
    }
  }
}
