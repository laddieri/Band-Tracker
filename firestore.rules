rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Any authenticated user (director or anonymous student) can read
    // Non-anonymous users (directors) can write
    match /students/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    match /rehearsals/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    match /entries/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    match /songs/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Only directors (non-anonymous) can read admin list
    match /admins/{doc} {
      allow read: if request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
      allow write: if false; // managed via Firebase console only
    }
  }
}
